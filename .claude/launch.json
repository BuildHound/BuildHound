{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "brand-site",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8791", "--directory", "docs/brand/site"],
      "port": 8791
    },
    {
      "name": "buildhound-server-dev",
      "runtimeExecutable": "sh",
      "runtimeArgs": [
        "-c",
        "BUILDHOUND_DEV_TOKEN=\"${BUILDHOUND_DEV_TOKEN:-$(cat .claude/dev-token.local 2>/dev/null)}\" exec ./gradlew :buildhound-server:run"
      ],
      "port": 8080
    }
  ]
}
